<?php
session_start();
require_once __DIR__ . '/../db.php';

if (!isset($_SESSION['user_id'])) {
    header('Location: login.php');
    exit;
}

$id = isset($_GET['id']) ? (int)$_GET['id'] : 0;
$project = [
    'title' => '',
    'description' => '',
    'link' => '',
    'image' => '',
];

if ($id > 0) {
    $stmt = $pdo->prepare('SELECT * FROM projects WHERE id = ?');
    $stmt->execute([$id]);
    $project = $stmt->fetch() ?: $project;
}

$message = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $title = trim($_POST['title'] ?? '');
    $description = trim($_POST['description'] ?? '');
    $link = trim($_POST['link'] ?? '');
    $image = trim($_POST['image'] ?? '');

    if ($title === '' || $description === '') {
        $message = 'Title and description are required.';
    } else {
        if ($id > 0) {
            $stmt = $pdo->prepare('UPDATE projects SET title = ?, description = ?, link = ?, image = ? WHERE id = ?');
            $stmt->execute([$title, $description, $link, $image, $id]);
            $message = 'Project updated successfully.';
        } else {
            $stmt = $pdo->prepare('INSERT INTO projects (title, description, link, image) VALUES (?, ?, ?, ?)');
            $stmt->execute([$title, $description, $link, $image]);
            $message = 'Project added successfully.';
            $id = $pdo->lastInsertId();
        }

        // Refresh project data
        $stmt = $pdo->prepare('SELECT * FROM projects WHERE id = ?');
        $stmt->execute([$id]);
        $project = $stmt->fetch();
    }
}
?>
