        <a href="projects.php">Back to Projects</a>
        <a href="logout.php">Logout</a>
    </nav>
</header>

<section style="padding: 40px; color: white;">
    <?php if ($message): ?>
        <p style="color: #8f8;"><?php echo htmlspecialchars($message); ?></p>
    <?php endif; ?>

    <form method="POST" action="">
        <label>Title:</label><br>
        <input type="text" name="title" value="<?php echo htmlspecialchars($project['title']); ?>" required><br><br>
        <label>Description:</label><br>
        <textarea name="description" rows="6" required><?php echo htmlspecialchars($project['description']); ?></textarea><br><br>
        <label>Link (optional):</label><br>
        <input type="url" name="link" value="<?php echo htmlspecialchars($project['link']); ?>"><br><br>
        <label>Image URL (optional):</label><br>
        <input type="text" name="image" value="<?php echo htmlspecialchars($project['image']); ?>"><br><br>
        <button type="submit"><?php echo $id ? 'Save changes' : 'Create project'; ?></button>
    </form>
</section>
